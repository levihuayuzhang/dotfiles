[Unit]
PartOf=graphical-session.target
After=graphical-session.target
Requisite=graphical-session.target

[Service]
ExecStart=/usr/bin/swayidle -w timeout 601 'niri msg action power-off-monitors' timeout 600 'swaylock -f -i ~/wallpapers/2.jpg' timeout 900 'systemctl suspend' before-sleep 'swaylock -f -i ~/wallpapers/2.jpg'
Restart=on-failure
